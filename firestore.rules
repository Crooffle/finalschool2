rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /submissions/{submissionId} {
      allow create: if request.resource.data.serverSecret == "super_secret_backend_key";
      allow update, delete: if false; // immutable
      allow read: if resource.data.serverSecret == "super_secret_backend_key";
    }
  }
}
